# Скопіюй у .env і впиши свій ключ
OPENAI_API_KEY=sk-...

# Модель ембеддингу. 3-large = краща якість; можна 1024 виміри (Matryoshka) для легшого сховища.
OPENAI_EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072

# Локальний Qdrant (docker-compose up -d)
QDRANT_URL=http://localhost:6333

# Каталог з NDJSON, експортованими з Drupal (public://agrorag_export/*.ndjson)
# Якщо не задано — береться ./export поруч із цим проєктом.
EXPORT_DIR=


AGRO_API_BASE=http://agrarii


CACHE_THRESHOLD=0.90